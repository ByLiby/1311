{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/[lang]",
      "regex": "^/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[lang]/automobilkunstleder",
      "regex": "^/([^/]+?)/automobilkunstleder(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/automobilkunstleder(?:/)?$"
    },
    {
      "page": "/[lang]/contact",
      "regex": "^/([^/]+?)/contact(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/contact(?:/)?$"
    },
    {
      "page": "/[lang]/datenschutz",
      "regex": "^/([^/]+?)/datenschutz(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/datenschutz(?:/)?$"
    },
    {
      "page": "/[lang]/impressum",
      "regex": "^/([^/]+?)/impressum(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/impressum(?:/)?$"
    },
    {
      "page": "/[lang]/material-viewer/[category]/[materialId]",
      "regex": "^/([^/]+?)/material\\-viewer/([^/]+?)/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang",
        "nxtPcategory": "nxtPcategory",
        "nxtPmaterialId": "nxtPmaterialId"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/material\\-viewer/(?<nxtPcategory>[^/]+?)/(?<nxtPmaterialId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[lang]/other",
      "regex": "^/([^/]+?)/other(?:/)?$",
      "routeKeys": {
        "nxtPlang": "nxtPlang"
      },
      "namedRegex": "^/(?<nxtPlang>[^/]+?)/other(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/automobilkunstleder",
      "regex": "^/automobilkunstleder(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/automobilkunstleder(?:/)?$"
    },
    {
      "page": "/contact",
      "regex": "^/contact(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact(?:/)?$"
    },
    {
      "page": "/datenschutz",
      "regex": "^/datenschutz(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/datenschutz(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/impressum",
      "regex": "^/impressum(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/impressum(?:/)?$"
    },
    {
      "page": "/other",
      "regex": "^/other(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/other(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}